{
  "name": "copa-funtour-2026",
  "version": "1.0.0",
  "private": true,
  "description": "App de inscripciones de la Copa FunTour 2026 (fútbol y vóley)",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma db push --accept-data-loss --skip-generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "sheets:resync": "tsx scripts/resync.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "clsx": "^2.1.1",
    "googleapis": "^144.0.0",
    "jose": "^5.9.6",
    "next": "14.2.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "dotenv": "^16.4.5",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.17"
  }
